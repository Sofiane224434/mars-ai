# Serveur
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=starter_kit

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Brevo (email transactionnel)
BREVO_API_KEY=xkeysib-your_api_key_here
BREVO_SENDER_EMAIL=you@example.com
BREVO_SENDER_NAME=MarsAI

# Scaleway S3 Configuration
SCALEWAY_ACCESS_KEY= access key
SCALEWAY_SECRET_KEY= secret key
SCALEWAY_ENDPOINT= https://s3.fr-par.scw.cloud
SCALEWAY_BUCKET_NAME= bucket name
SCALEWAY_REGION= region
SCALEWAY_FOLDER= folder name

# DeepL
DEEPL_API_KEY=your_deepl_api_key
